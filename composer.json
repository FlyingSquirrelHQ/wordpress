{
	"name": "flyingsquirrelhq/wordpress",
	"description": "WordPress image and stack — PHPCS and PHPUnit.",
	"license": "proprietary",
	"require-dev": {
		"doctrine/instantiator": "~2.0.0",
		"phpunit/phpunit": "^9.6",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"phpunit": "phpunit",
		"test": [
			"@phpcs"
		],
		"test:all": [
			"@phpcs",
			"@phpunit"
		]
	}
}
