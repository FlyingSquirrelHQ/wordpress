# =============================================================================
# Environment template for local development
# =============================================================================
# Copy to `.env` and edit. Do not commit real secrets.
#
#   cp .env.example .env
#
# Start:
#
#   docker network create stackcar   # once, if stack_car `sc proxy` is not running
#   docker compose up -d
#
# This file is the single source of runtime config:
#   - `docker compose` reads it for ${VAR} substitution (ports, Traefik labels, db mapping).
#   - Both `db` and `wordpress` services use `env_file: .env` (see docker-compose.yml).
#
# Naming:
#   WORDPRESS_* — consumed by the official image for wp-config.php (keep these tight;
#                 the container log lists WORDPRESS_* keys when generating wp-config).
#   WP_*        — bootstrap / WP-CLI install / multisite helper (not wp-config.php).
#
# Keep `WORDPRESS_DB_*` and `MARIADB_ROOT_PASSWORD` in sync with expectations below.
# =============================================================================


# -----------------------------------------------------------------------------
# Compose (optional)
# -----------------------------------------------------------------------------
# Prefix for container, volume, and network resource names when not overridden.
# COMPOSE_PROJECT_NAME=wordpress

# Host port mapped to WordPress Apache :80. Use http://localhost:${WP_PORT} only
# if you set WP_SITE_URL to match; default URLs use localhost.direct + Traefik.
WP_PORT=8080

# Only when using `docker compose --profile traefik` (avoid if sc proxy already uses 80/443):
# TRAEFIK_HTTP_PORT=80
# TRAEFIK_HTTPS_PORT=443


# -----------------------------------------------------------------------------
# Stack identity & Traefik (Hyku / stack_car pattern)
# -----------------------------------------------------------------------------
# Short name for this project on your machine. Used in:
#   - Traefik router/service names: wp-${APP_NAME}
#   - Install URL default: wp-${APP_NAME}.localhost.direct (see WP_SITE_URL)
#
# If you change APP_NAME, update WP_SITE_URL and WP_DOMAIN_CURRENT_SITE (or delete
# those lines so defaults in scripts track APP_NAME where applicable).
APP_NAME=wordpress

# Derived hosts (Traefik labels in docker-compose.yml; TLS on entrypoint `websecure`):
#   Main:     https://wp-${APP_NAME}.localhost.direct
#   Tenants:  https://<slug>.wp-${APP_NAME}.localhost.direct  (subdomain multisite)
#
# *.localhost.direct resolves to 127.0.0.1 — see https://readme.localhost.direct/


# -----------------------------------------------------------------------------
# MariaDB (service: db)
# -----------------------------------------------------------------------------
# Database name, user, and password are shared by MariaDB bootstrap and WordPress.
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me-strong-password

# MariaDB superuser (host port is not published by default; used for admin tasks).
MARIADB_ROOT_PASSWORD=change-me-root-password

# WordPress → database TCP target (service name `db` on the Compose network).
WORDPRESS_DB_HOST=db:3306


# -----------------------------------------------------------------------------
# WordPress: wp-config.php (official image — use WORDPRESS_* only here)
# -----------------------------------------------------------------------------
# Table prefix. Use unique values for multiple logical sites in one database.
WORDPRESS_TABLE_PREFIX=wp_

# Set to 1 to enable WP_DEBUG (display of notices during development).
WORDPRESS_DEBUG=

# Extra PHP executed in wp-config (official image evals WORDPRESS_CONFIG_EXTRA).
# Use for defines() not covered below. Multiline: use quoted YAML in compose or a single line.
# Example: WORDPRESS_CONFIG_EXTRA=define('AUTOMATIC_UPDATER_DISABLED', true);
WORDPRESS_CONFIG_EXTRA=

# Optional — supported by docker-library/wordpress wp-config-docker.php but not passed
# from docker-compose.yml by default. Add under wordpress.environment if needed:
#
# WORDPRESS_DB_CHARSET=utf8mb4
# WORDPRESS_DB_COLLATE=
#
# Authentication unique keys and salts (generate: https://api.wordpress.org/secret-key/1.1/salt/):
# WORDPRESS_AUTH_KEY=
# WORDPRESS_SECURE_AUTH_KEY=
# WORDPRESS_LOGGED_IN_KEY=
# WORDPRESS_NONCE_KEY=
# WORDPRESS_AUTH_SALT=
# WORDPRESS_SECURE_AUTH_SALT=
# WORDPRESS_LOGGED_IN_SALT=
# WORDPRESS_NONCE_SALT=
#
# Or use *_FILE variants for Docker secrets, e.g. WORDPRESS_AUTH_KEY_FILE=/run/secrets/...


# -----------------------------------------------------------------------------
# Public site URL & title (WP-CLI install → database; not read into wp-config.php)
# -----------------------------------------------------------------------------
# Must match the URL users type in the browser (scheme, host, port).
WP_SITE_URL=https://wp-wordpress.localhost.direct
WP_SITE_TITLE=WordPress


# -----------------------------------------------------------------------------
# Automated install (WP-CLI on first container start)
# -----------------------------------------------------------------------------
# The custom image sets WP_AUTO_INSTALL=on by default (Dockerfile ENV). You can omit
# this line; set to 0/false/off here or in Compose to use the browser installer instead.
#
# When set to 1, true, yes, or on, runs `wp core install` if the database is empty.
# Requires WP_ADMIN_PASSWORD and WP_ADMIN_EMAIL.
# Set to 0, false, or off to use the browser “five-minute install” instead.
#
# Important: after you complete (or partially complete) the web installer, WordPress
# is “installed” in the DB — startup will skip WP-CLI install and your WP_* title/user
# vars will not re-run. For a clean automated install: `docker compose down -v` then
# `docker compose up -d` (drops MariaDB data), or remove only the `db_data` volume.
WP_AUTO_INSTALL=on

WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-me-admin-password
WP_ADMIN_EMAIL=admin@example.com

# Search engine visibility: 1 = allow indexing, 0 or false = discourage (installer option).
WP_BLOG_PUBLIC=1

# Core install locale, e.g. en_US, fr_FR (optional).
WP_INSTALL_LOCALE=en_US

# Legacy names (still supported): WORDPRESS_AUTO_INSTALL, WORDPRESS_SITE_URL,
# WORDPRESS_SITE_TITLE, WORDPRESS_ADMIN_*, WORDPRESS_BLOG_PUBLIC, WORDPRESS_LOCALE


# -----------------------------------------------------------------------------
# Multisite / proxy helpers (docker-entrypoint-multitenant.sh → WORDPRESS_CONFIG_EXTRA)
# -----------------------------------------------------------------------------
# WP_MULTISITE_MODE (case-insensitive):
#   off — normal single site (still one container; Traefik can route many hostnames to it).
#   prepare / on / true / yes / 1 — only sets WP_ALLOW_MULTISITE; you still have ONE site
#     until you run wp-admin → Tools → Network Setup and create the network.
#   network — full MULTISITE defines in wp-config; use after the network exists and
#     constants match what WordPress generated (see README multisite section).
#
# “Multitenant” here = optional WordPress Multisite + Traefik *.wp-${APP_NAME}.localhost.direct.
WP_MULTISITE_MODE=off

# Subdomain vs subdirectory multisite when WP_MULTISITE_MODE=network (true|false).
# For tenant hosts like https://tenant.wp-wordpress.localhost.direct use true after network setup.
WP_SUBDOMAIN_INSTALL=false

# Primary domain for the network, no scheme. Must match Traefik host for apex site.
WP_DOMAIN_CURRENT_SITE=wp-wordpress.localhost.direct

# Path for the network root (usually /).
WP_PATH_CURRENT_SITE=/

WP_SITE_ID_CURRENT_SITE=1
WP_BLOG_ID_CURRENT_SITE=1

# When true/1, trust X-Forwarded-Proto and X-Forwarded-Host (Traefik / TLS offload).
WP_BEHIND_REVERSE_PROXY=true


# -----------------------------------------------------------------------------
# First-boot notes (official WordPress entrypoint)
# -----------------------------------------------------------------------------
# • “WordPress not found … copying now” — normal on a fresh /var/www/html.
# • WARNINGS for wp-content/plugins|themes — you bind-mount ./wp-content; the entrypoint
#   skips overwriting those paths so your tree wins over the image tarball (expected).
# • wp-config.php line should list only WORDPRESS_DB_*, WORDPRESS_TABLE_PREFIX,
#   WORDPRESS_DEBUG, WORDPRESS_CONFIG_EXTRA, salts — not install/bootstrap vars (use WP_*).
# • With WP_AUTO_INSTALL, WP-CLI runs before Apache binds :80 (avoids racing the browser
#   installer). Traefik may show 502 / connection refused until Apache starts (~60s if the
#   DB is slow). If headless install fails, Apache still starts so you can use the web UI.
#
# Rebuild after changing Dockerfile build-args (WORDPRESS_VERSION, PHP, WP-CLI):
#   docker compose build --no-cache wordpress
